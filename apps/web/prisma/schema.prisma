generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Crash {
  id               String   @id @default(cuid())
  projectName      String
  environment      String
  route            String
  provider         String
  model            String
  promptVersion    String?
  systemPrompt     String?
  userInput        String?
  retrievedContext String?
  toolCalls        String?
  output           String?
  expectedBehavior String?
  failureType      String
  severity         String
  reproducible     Boolean  @default(false)
  metadata         String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([failureType])
  @@index([severity])
}
