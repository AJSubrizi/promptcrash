{
  "name": "@promptcrash/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema prisma/schema.prisma && next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "prisma generate --schema prisma/schema.prisma && tsc --noEmit",
    "test": "corepack pnpm --filter @promptcrash/sdk build && vitest run",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:init": "prisma db execute --file prisma/init.sql --schema prisma/schema.prisma && prisma generate --schema prisma/schema.prisma",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/xai": "^1.1.7",
    "@prisma/client": "^6.2.1",
    "@promptcrash/sdk": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "ai": "^4.0.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
