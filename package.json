{
  "name": "promptcrash",
  "private": true,
  "version": "0.1.0",
  "description": "PromptCrash turns bad LLM outputs into reproducible bugs.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AJSubrizi/promptcrash.git"
  },
  "bugs": {
    "url": "https://github.com/AJSubrizi/promptcrash/issues"
  },
  "homepage": "https://github.com/AJSubrizi/promptcrash#readme",
  "keywords": [
    "llm",
    "ai",
    "debugging",
    "crash-reporting",
    "grok",
    "xai",
    "redaction",
    "regression-tests"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @promptcrash/web dev",
    "build": "corepack pnpm -r --workspace-concurrency=1 build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "corepack pnpm -r --workspace-concurrency=1 typecheck",
    "test": "corepack pnpm -r --workspace-concurrency=1 test",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "db:init": "corepack pnpm --filter @promptcrash/web db:init",
    "db:seed": "corepack pnpm --filter @promptcrash/web db:seed"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.1.4",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
